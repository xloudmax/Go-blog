# 环境配置文件
# 已设置安全的生产级密钥

# 应用环境 (debug, release, test)
GIN_MODE=release
GO_ENV=production

# 服务器配置
PORT=11451

# 数据库配置
DATABASE_URL=blog_platform.db

# JWT 安全密钥 (已生成强随机密钥)
JWT_SECRET=X5cIMqG0p7tqKlSPvx408x660KtbtXsdzwCYdjJWn09bJwY2Fpwya91sadot108A

# 管理员邀请码 (用于首次创建管理员账号)
ADMIN_INVITE_CODE=76e2f0f3a8ee99ce498376118af55293

# 日志配置
LOG_LEVEL=info

# 邮件配置
# 注意：SMTP_PASSWORD 应该使用 Gmail App Password，而不是您的常规 Gmail 密码
# 如何创建 App Password: https://myaccount.google.com/apppasswords
# 1. 访问上述链接（需要启用两步验证）
# 2. 选择"邮件"应用和设备
# 3. 生成密码并复制到下方 SMTP_PASSWORD
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=xloudmaxx@gmail.com
SMTP_PASSWORD=mbbfhrdewlpkbphe

# CORS 配置 (多个域名用逗号分隔)
ALLOWED_ORIGINS=https://xloudmax.cc,https://www.xloudmax.cc,http://localhost:5173

# 文件上传配置
BASE_URL=https://xloudmax.cc
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.md,.txt,.json

# 限流配置
RATE_LIMIT_ENABLED=true
REQUESTS_PER_MINUTE=100
REQUESTS_PER_HOUR=1000

# 安全配置
BCRYPT_COST=12
SESSION_TIMEOUT=24h
REFRESH_TOKEN_TIMEOUT=168h

# 缓存配置 (使用内存缓存，不需要Redis)
CACHE_ENABLED=true
CACHE_TTL=900s

# 前端URL（用于密码重置链接等）
FRONTEND_URL=https://xloudmax.cc

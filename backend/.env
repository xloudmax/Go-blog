# 环境配置文件

# 应用环境 (debug, release, test)
GIN_MODE=debug

# 服务器配置
PORT=11451

# 数据库配置
DATABASE_URL=blog_platform.db

# JWT 安全密钥 (生产环境请使用强密码)
JWT_SECRET=JNU_technicians_club

# 日志配置
LOG_LEVEL=info

# 邮件配置
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# CORS 配置 (多个域名用逗号分隔)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://0.0.0.0:5173

# 文件上传配置
BASE_PATH=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.md,.txt,.json

# 限流配置
RATE_LIMIT_ENABLED=true
REQUESTS_PER_MINUTE=100
REQUESTS_PER_HOUR=1000

# 安全配置
BCRYPT_COST=12
SESSION_TIMEOUT=24h
REFRESH_TOKEN_TIMEOUT=168h

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=900s

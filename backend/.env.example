# 环境配置文件示例
# 复制此文件为 .env 并填入真实的配置值

# 应用环境 (debug, release, test)
GIN_MODE=release
GO_ENV=production

# 服务器配置
PORT=11451

# 数据库配置
# 开发环境使用 SQLite: blog_platform.db
# 生产环境使用 PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=blog_platform.db

# JWT 安全密钥 (生产环境必须使用强随机密钥！使用 openssl rand -base64 32 生成)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 管理员邀请码 (可选，用于首次创建管理员账号)
# 留空则禁用管理员邀请码注册功能
ADMIN_INVITE_CODE=

# 日志配置
LOG_LEVEL=info

# 邮件配置
# 注意：对于 Gmail，SMTP_PASSWORD 应该使用 App Password（16位字符，无空格）
# 如何创建 Gmail App Password: https://myaccount.google.com/apppasswords
# 1. 需要先启用两步验证
# 2. 访问上述链接并选择"邮件"应用
# 3. 生成密码并复制到 SMTP_PASSWORD
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# CORS 配置 (多个域名用逗号分隔)
# 生产环境示例: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# 文件上传配置
BASE_URL=http://localhost:11451
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.md,.txt,.json

# 限流配置
RATE_LIMIT_ENABLED=true
REQUESTS_PER_MINUTE=60
REQUESTS_PER_HOUR=1000

# 安全配置
BCRYPT_COST=12
SESSION_TIMEOUT=24h
REFRESH_TOKEN_TIMEOUT=168h

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=900s
